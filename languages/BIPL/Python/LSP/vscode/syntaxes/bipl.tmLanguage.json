{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BIPL",
  "scopeName": "source.bipl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.bipl", "match": "//.*$" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.bipl", "match": "\\b(if|else|while)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.integer.bipl", "match": "\\b[0-9]+\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.logical.bipl", "match": "\\|\\||&&|!" },
        { "name": "keyword.operator.comparison.bipl", "match": "<=|==|>=|<|>" },
        { "name": "keyword.operator.assignment.bipl", "match": "=" },
        { "name": "keyword.operator.arithmetic.bipl", "match": "[+*-]" }
      ]
    },
    "identifiers": {
      "patterns": [
        { "name": "variable.other.bipl", "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b" }
      ]
    }
  }
}
